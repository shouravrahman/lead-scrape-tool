# .streamlit/secrets.toml.example
# Copy this structure into the Streamlit Cloud Secrets editor
# (App Settings → Secrets). Do NOT commit the real secrets.toml file.

# --- Database (Neon PostgreSQL) ---
# Get this from your Neon project dashboard → Connection Details → Connection string
DATABASE_URL = "postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# --- Encryption (Required) ---
ENCRYPTION_KEY = "your_encryption_key_here"

# --- LLM / AI ---
OPENROUTER_API_KEYS = "sk-or-..."
PLANNER_MODEL     = "google/gemini-flash-1.5-free"
EXTRACTOR_MODEL   = "google/gemini-flash-1.5-free"

# --- Scraper API Keys (comma-separated for rotation) ---
SERP_API_KEYS     = "key1,key2,key3"
SERPER_API_KEYS   = "key1,key2"
TAVILY_API_KEYS   = "key1"
FIRECRAWL_API_KEYS= "key1,key2"

# --- Google Sheets (optional) ---
GOOGLE_SHEET_ID          = "your_sheet_id_here"
GOOGLE_CREDENTIALS_JSON  = '{"type": "service_account", ...}'
AUTO_SYNC_TO_SHEETS      = "true"
