# 🔒 REFERENCE: Copy values from ../.env (root) - Do NOT commit this file!
# The backend reads environment variables from the root .env file
# This file is for reference only to show what variables are needed

DATABASE_URL=postgresql://neondb_owner:password@your-host/neondb
ENCRYPTION_KEY=your-fernet-key-here
OPENROUTER_API_KEYS=your-key-1,your-key-2
PLANNER_MODEL=google/gemini-flash-1.5-free
EXTRACTOR_MODEL=google/gemini-flash-1.5-free
ASSISTANT_MODEL=google/gemini-flash-1.5-free
SERP_API_KEYS=your-serp-keys
SERPER_API_KEYS=your-serper-keys
TAVILY_API_KEYS=your-tavily-keys
FIRECRAWL_API_KEYS=your-firecrawl-keys
GOOGLE_SHEET_ID=your-sheet-id
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project"}
AUTO_SYNC_TO_SHEETS=true
LOG_LEVEL=INFO
ENVIRONMENT=development
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
VUE_APP_API_URL=http://localhost:8000/api
