# --- Intelligence & LLM Config ---
# OpenRouter is the primary recommended provider for free tiers (Gemini Flash).
# Ollama allows for 100% local, free execution with models like 'llama3' or 'mistral'.
# The system uses the 'openai' python client as a universal bridge for all providers.

# 1. OpenRouter (Recommended for Cloud Free-Tier)
OPENROUTER_API_KEY=your_openrouter_key_here
PLANNER_MODEL=google/gemini-flash-1.5-free
EXTRACTOR_MODEL=google/gemini-flash-1.5-free

# 2. Ollama (Recommended for 100% Local/Private/Free)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# PLANNER_MODEL=llama3
# EXTRACTOR_MODEL=llama3

# 3. Direct OpenAI (Optional)
OPENAI_API_KEY=

# --- Scraper API Keys ---
# For rotation: KEY1,KEY2,KEY3
SERP_API_KEYS=your_serp_api_keys_here
SERPER_API_KEYS=your_serper_keys_here
TAVILY_API_KEYS=your_tavily_keys_here
FIRECRAWL_API_KEYS=your_firecrawl_api_keys_here

# --- Database ---
DATABASE_URL=sqlite:///./lead_engine.db

# --- Google Sheets ---
GOOGLE_SHEET_ID=your_sheet_id_here
GOOGLE_CREDENTIALS_FILE=credentials.json
AUTO_SYNC_TO_SHEETS=true
