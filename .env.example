# ⚠️ SECURITY: Never commit this file to git!
# Add to .gitignore if not already: .env

# ===============================
# ENCRYPTION (CRITICAL - NEW)
# ===============================
# 🔐 REQUIRED: Generate encryption key for all sensitive data
# Command: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_encryption_key_here

# ===============================
# DATABASE (CRITICAL)
# ===============================
# Neon PostgreSQL serverless recommended
# Get connection string from https://neon.tech → Project → Connection Details
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ===============================
# API KEYS (ENCRYPTED - NEW SECURITY)
# ===============================
# 🔐 IMPORTANT: Keys should be encrypted with ENCRYPTION_KEY
# Generate encrypted value:
#   python3 << 'EOF'
#   from lead_engine.security.encryption import SecretManager
#   key = "your-api-key"
#   print(f"encrypted:{SecretManager.encrypt(key)}")
#   EOF
#
# Format: encrypted:gAAAAAB...encrypted_data... (or comma-separated for multiple keys)
# Legacy (plaintext) still works but will show warning

SERP_API_KEYS=encrypted:gAAAAAB...
SERPER_API_KEYS=encrypted:gAAAAAB...
TAVILY_API_KEYS=encrypted:gAAAAAB...
FIRECRAWL_API_KEYS=encrypted:gAAAAAB...
OPENROUTER_API_KEYS=encrypted:gAAAAAB...

# ===============================
# LLM MODELS
# ===============================
# OpenRouter (Recommended for free tier)
PLANNER_MODEL=google/gemini-flash-1.5-free
EXTRACTOR_MODEL=google/gemini-flash-1.5-free

# Ollama (100% local, optional)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# PLANNER_MODEL=llama3
# EXTRACTOR_MODEL=llama3

# ===============================
# GOOGLE SHEETS (ENCRYPTED - NEW SECURITY)
# ===============================
# Sheet ID: Extract from URL (44 alphanumeric characters)
GOOGLE_SHEET_ID=your_44_char_sheet_id

# Google service account credentials JSON content as string
# Paste the entire content of your credentials.json file here (single line or quoted)
GOOGLE_CREDENTIALS_JSON='{"type": "service_account", ...}'

# Auto-sync high-score (>15pts) leads to Google Sheets
AUTO_SYNC_TO_SHEETS=true

# ===============================
# LOGGING & MONITORING (NEW)
# ===============================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ===============================
# SECURITY SETUP CHECKLIST
# ===============================
#
# [ ] 1. Generate ENCRYPTION_KEY:
#        python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# [ ] 2. Add ENCRYPTION_KEY to this file
#
# [ ] 3. Encrypt your API keys:
#        python3 << 'EOF'
#        from lead_engine.security.encryption import SecretManager
#        api_key = "your-api-key"
#        encrypted = SecretManager.encrypt(api_key)
#        print(f"encrypted:{encrypted}")
#        EOF
#
# [ ] 4. Add encrypted keys to SERP_API_KEYS, etc.
#
# [ ] 5. Set file permissions (Linux/Mac):
#        chmod 600 .env
#        chmod 600 credentials.json
#
# [ ] 6. Initialize database:
#        python3 -c "from lead_engine.db.models import init_db; init_db()"
#
# [ ] 7. (Optional) Enable Streamlit authentication:
#        Create .streamlit/secrets.toml with auth config
#
# [ ] 8. Run application:
#        streamlit run streamlit_app.py
#
# ===============================
