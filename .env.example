# ⚠️  SECURITY: Never commit this file to git!
# Copy to .env and fill in your actual values

# ===============================
# DATABASE (CRITICAL)
# ===============================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lead_scrape

# ===============================
# ENCRYPTION (CRITICAL)
# ===============================
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-32-character-encryption-key-here

# ===============================
# LLM CONFIGURATION (CrewAI)
# ===============================
# OpenRouter (Recommended - free tier)
OPENROUTER_API_KEYS=your-openrouter-key,backup-key
PLANNER_MODEL=google/gemini-flash-1.5-free
EXTRACTOR_MODEL=google/gemini-flash-1.5-free
ASSISTANT_MODEL=google/gemini-flash-1.5-free

# ===============================
# SEARCH API KEYS (Multi-key pooling)
# ===============================
SERPER_API_KEYS=key1,key2
TAVILY_API_KEYS=key1,key2
SERPAPI_API_KEYS=key1,key2
FIRECRAWL_API_KEYS=key1,key2

# ===============================
# GOOGLE SERVICES
# ===============================
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project"}

# Alternative: Ollama (local)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# PLANNER_MODEL=llama3
# EXTRACTOR_MODEL=llama3

# ===============================
# SEARCH PROVIDER KEYS (Multi-key pooling)
# ===============================
# Can be comma-separated for key rotation (e.g., key1,key2,key3)
SERP_API_KEYS=your-serp-key
SERPER_API_KEYS=your-serper-key
TAVILY_API_KEYS=your-tavily-key
FIRECRAWL_API_KEYS=your-firecrawl-key

# ===============================
# GOOGLE SHEETS INTEGRATION
# ===============================
# Sheet ID: Extract 44 alphanumeric characters from the Google Sheets URL
GOOGLE_SHEET_ID=your-44-character-sheet-id

# Credentials JSON from Google Cloud Service Account
# Paste the entire content or set to file path
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project","..."}

# Auto-sync leads with score > 15 to Google Sheets
AUTO_SYNC_TO_SHEETS=true

# ===============================
# BACKEND CONFIGURATION
# ===============================
ENVIRONMENT=development
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===============================
# FRONTEND CONFIGURATION
# ===============================
VUE_APP_API_URL=http://localhost:8000/api

# ===============================
# LOGGING
# ===============================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
